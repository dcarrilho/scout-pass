generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum TargetType {
  CITY
  WAYPOINT
  LANDMARK
  BORDER
}

enum CheckInStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FollowStatus {
  PENDING
  ACCEPTED
}

enum LinkStatus {
  PENDING
  ACCEPTED
}

enum NotificationType {
  CHECKIN_APPROVED
  CHECKIN_REJECTED
  CHECKIN_PENDING_REVIEW
  NEW_FOLLOWER
  FOLLOW_ACCEPTED
  REACTION
  COMMENT
  FIRST_CHECKIN
  MILESTONE
  CHALLENGE_COMPLETED
  GARUPA_ACCEPTED
}

enum ModerationMode {
  PUBLIC
  PRIVATE
}

model User {
  id                String         @id @default(cuid())
  name              String
  username          String         @unique
  email             String         @unique
  password          String
  bio               String?
  avatar_url        String?
  cover_url         String?
  is_private        Boolean        @default(false)
  role              Role           @default(USER)
  motorcycles       Motorcycle[]
  checkins          CheckIn[]      @relation("UserCheckIns")
  collab_checkins   CheckIn[]      @relation("CollabCheckIns")
  reviewed_checkins CheckIn[]      @relation("ReviewedCheckIns")
  following         Follow[]       @relation("Follower")
  followers         Follow[]       @relation("Following")
  piloto_links      PilotoGarupa[] @relation("Piloto")
  garupa_links      PilotoGarupa[] @relation("Garupa")
  notifications        Notification[] @relation("UserNotifications")
  actor_notifications  Notification[] @relation("ActorNotifications")
  reactions            Reaction[]
  comments             Comment[]
  moderated_challenges  ChallengeModerator[]
  challenge_participations ChallengeParticipant[]
  created_at            DateTime             @default(now())
  updated_at           DateTime             @updatedAt
}

model Motorcycle {
  id            String    @id @default(cuid())
  user_id       String
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  brand         String
  model         String
  year          Int
  license_plate String?
  owned_from    Int?
  owned_until   Int?
  is_active     Boolean   @default(true)
  checkins      CheckIn[]
  created_at    DateTime  @default(now())
}

model Follow {
  id           String       @id @default(cuid())
  follower_id  String
  follower     User         @relation("Follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following_id String
  following    User         @relation("Following", fields: [following_id], references: [id], onDelete: Cascade)
  status       FollowStatus @default(PENDING)
  created_at   DateTime     @default(now())

  @@unique([follower_id, following_id])
}

model PilotoGarupa {
  id         String     @id @default(cuid())
  piloto_id  String
  piloto     User       @relation("Piloto", fields: [piloto_id], references: [id], onDelete: Cascade)
  garupa_id  String
  garupa     User       @relation("Garupa", fields: [garupa_id], references: [id], onDelete: Cascade)
  status     LinkStatus @default(PENDING)
  created_at DateTime   @default(now())

  @@unique([piloto_id, garupa_id])
}

model Organizer {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  logo_url    String?
  cover_url   String?
  is_active   Boolean     @default(true)
  series      Series[]
  challenges  Challenge[]
  created_at  DateTime    @default(now())
}

model Series {
  id           String      @id @default(cuid())
  organizer_id String?
  organizer    Organizer?  @relation(fields: [organizer_id], references: [id])
  name         String
  description  String?
  icon         String?
  color        String?
  cover_url    String?
  order        Int         @default(0)
  is_active    Boolean     @default(true)
  challenges   Challenge[]
  created_at   DateTime    @default(now())
}

model Challenge {
  id              String               @id @default(cuid())
  organizer_id    String?
  organizer       Organizer?           @relation(fields: [organizer_id], references: [id])
  series_id       String?
  series          Series?              @relation(fields: [series_id], references: [id])
  name            String
  description     String?
  state_code      String?
  cover_url       String?
  is_active       Boolean              @default(true)
  moderation_mode ModerationMode         @default(PUBLIC)
  targets         ChallengeTarget[]      @relation("ChallengeTargets")
  checkins        CheckIn[]
  moderators      ChallengeModerator[]
  participants    ChallengeParticipant[]
  notifications   Notification[]
  created_at      DateTime               @default(now())
}

model ChallengeParticipant {
  id           String    @id @default(cuid())
  challenge_id String
  challenge    Challenge @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
  user_id      String
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  joined_at    DateTime  @default(now())

  @@unique([challenge_id, user_id])
}

model ChallengeModerator {
  id           String    @id @default(cuid())
  challenge_id String
  challenge    Challenge @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
  user_id      String
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at   DateTime  @default(now())

  @@unique([challenge_id, user_id])
}

model City {
  id        String            @id @default(cuid())
  ibge_code String            @unique
  name      String
  state     String
  region    String
  latitude  Float?
  longitude Float?
  targets   ChallengeTarget[]
}

model ChallengeTarget {
  id         String      @id @default(cuid())
  name       String
  city_id    String?
  city       City?       @relation(fields: [city_id], references: [id])
  latitude   Float?
  longitude  Float?
  order      Int         @default(0)
  type       TargetType  @default(CITY)
  checkins   CheckIn[]
  challenges Challenge[] @relation("ChallengeTargets")
  created_at DateTime    @default(now())
}

model CheckIn {
  id               String          @id @default(cuid())
  user_id          String
  user             User            @relation("UserCheckIns", fields: [user_id], references: [id], onDelete: Cascade)
  collab_user_id   String?
  collab_user      User?           @relation("CollabCheckIns", fields: [collab_user_id], references: [id])
  challenge_id     String
  challenge        Challenge       @relation(fields: [challenge_id], references: [id])
  target_id        String
  target           ChallengeTarget @relation(fields: [target_id], references: [id])
  motorcycle_id    String?
  motorcycle       Motorcycle?     @relation(fields: [motorcycle_id], references: [id])
  photo_url        String
  exif_latitude    Float?
  exif_longitude   Float?
  exif_taken_at    DateTime?
  declared_target  String?
  status           CheckInStatus   @default(PENDING)
  rejection_reason String?
  reviewed_by      String?
  reviewer         User?           @relation("ReviewedCheckIns", fields: [reviewed_by], references: [id])
  reviewed_at      DateTime?
  submitted_at     DateTime        @default(now())
  notifications    Notification[]
  reactions        Reaction[]
  comments         Comment[]
}

model Reaction {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  checkin_id String
  checkin    CheckIn  @relation(fields: [checkin_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@unique([user_id, checkin_id])
}

model Comment {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  checkin_id String
  checkin    CheckIn  @relation(fields: [checkin_id], references: [id], onDelete: Cascade)
  content    String
  created_at DateTime @default(now())
}

model Notification {
  id           String           @id @default(cuid())
  user_id      String
  user         User             @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade)
  type         NotificationType
  actor_id     String?
  actor        User?            @relation("ActorNotifications", fields: [actor_id], references: [id], onDelete: SetNull)
  checkin_id   String?
  checkin      CheckIn?         @relation(fields: [checkin_id], references: [id], onDelete: SetNull)
  challenge_id String?
  challenge    Challenge?       @relation(fields: [challenge_id], references: [id], onDelete: SetNull)
  metadata     String?
  read         Boolean          @default(false)
  created_at   DateTime         @default(now())
}
